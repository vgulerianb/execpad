{
  "name": "agentpad",
  "version": "0.1.0",
  "description": "Multi-language code execution against a real directory for AI agents",
  "keywords": [
    "ai",
    "agents",
    "sandbox",
    "code-execution",
    "subprocess",
    "bash",
    "python",
    "nodejs",
    "sqlite",
    "openai",
    "tool-calling",
    "ci"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vgulerianb/agentpad.git"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "docs", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "build:tsc": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "minimatch": "^9.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.3.5",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
